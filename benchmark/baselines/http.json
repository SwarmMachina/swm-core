{
  "schemaVersion": "regression-ci-baseline/v1",
  "suite": "http",
  "benchmark": {
    "name": "http-core-ci",
    "packageName": "@swarmmachina/swm-core",
    "packageVersion": "1.2.0",
    "runner": "benchmark/regression-ci.js",
    "script": "npm run profile:ci -- --suite http",
    "framework": "core"
  },
  "calibration": {
    "status": "self-hosted-calibrated",
    "updatedAt": "2026-06-14",
    "node": "24.x",
    "ciRunner": "self-hosted (dedicated, schedutil)",
    "note": "Calibrated from 4 self-hosted runs (throughput spread 3-8%, memory <2%). Thresholds sit ~10-15% past the observed floor to catch real regressions. rssMB is report-only."
  },
  "parameters": {
    "runs": 3,
    "warmupSec": 2,
    "durationSec": 6,
    "connections": 100,
    "sampleMs": 250,
    "cpuProfile": true
  },
  "metrics": {
    "rps": { "label": "RPS", "unit": "req/s" },
    "latencyP99Ms": { "label": "p99", "unit": "ms" },
    "errors": { "label": "errors", "unit": "" },
    "heapMB": { "label": "heap peak", "unit": "MB" },
    "externalMB": { "label": "external peak", "unit": "MB" },
    "arrayBuffersMB": { "label": "arrayBuffers peak", "unit": "MB" },
    "rssMB": { "label": "rss peak", "unit": "MB" }
  },
  "tests": {
    "base": {
      "description": "GET /base JSON response hot path",
      "observedMedian": {
        "rps": 115093,
        "latencyAvgMs": 8.08,
        "latencyP97_5Ms": 9,
        "latencyP99Ms": 9.5,
        "errors": 0,
        "eluPct": 97.16,
        "eventLoopDelayP99Ms": 22.64,
        "rssMB": 73.08,
        "heapMB": 10.85,
        "externalMB": 3.57,
        "arrayBuffersMB": 0.04
      },
      "guards": {
        "rps": { "min": 99000 },
        "latencyP99Ms": { "max": 20 },
        "errors": { "max": 0 },
        "heapMB": { "max": 18 },
        "externalMB": { "max": 6 },
        "arrayBuffersMB": { "max": 2 }
      },
      "reportOnly": ["latencyAvgMs", "latencyP97_5Ms", "eluPct", "eventLoopDelayP99Ms", "rssMB"]
    },
    "headers": {
      "description": "GET /headers response header staging and repeated Set-Cookie path",
      "observedMedian": {
        "rps": 103403,
        "latencyAvgMs": 9.09,
        "latencyP97_5Ms": 10,
        "latencyP99Ms": 11,
        "errors": 0,
        "eluPct": 97.25,
        "eventLoopDelayP99Ms": 24.65,
        "rssMB": 76.88,
        "heapMB": 12.04,
        "externalMB": 3.57,
        "arrayBuffersMB": 0.04
      },
      "guards": {
        "rps": { "min": 92000 },
        "latencyP99Ms": { "max": 22 },
        "errors": { "max": 0 },
        "heapMB": { "max": 18 },
        "externalMB": { "max": 6 },
        "arrayBuffersMB": { "max": 2 }
      },
      "reportOnly": ["latencyAvgMs", "latencyP97_5Ms", "eluPct", "eventLoopDelayP99Ms", "rssMB"]
    },
    "post-base": {
      "description": "POST /base JSON body parsing hot path",
      "observedMedian": {
        "rps": 31508,
        "latencyAvgMs": 2.6,
        "latencyP97_5Ms": 5.5,
        "latencyP99Ms": 5.5,
        "errors": 0,
        "eluPct": 97.18,
        "eventLoopDelayP99Ms": 22.59,
        "rssMB": 73.72,
        "heapMB": 10.82,
        "externalMB": 3.6,
        "arrayBuffersMB": 0.07
      },
      "guards": {
        "rps": { "min": 26000 },
        "latencyP99Ms": { "max": 12 },
        "errors": { "max": 0 },
        "heapMB": { "max": 18 },
        "externalMB": { "max": 6 },
        "arrayBuffersMB": { "max": 2 }
      },
      "reportOnly": ["latencyAvgMs", "latencyP97_5Ms", "eluPct", "eventLoopDelayP99Ms", "rssMB"]
    }
  },
  "cpuProfileGuard": {
    "profileRequired": true,
    "minTotalTicks": 100,
    "maxGcPct": 10,
    "maxUnaccountedPct": 60,
    "note": "Sanity check only. Unaccounted% is high (~46%) and stable for a network server under load."
  }
}
